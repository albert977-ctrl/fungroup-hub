# ═══════════════════════════════════════════════════════════════
# The Fun Group Miami — Unified Dashboard Configuration
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Gmail Configuration ──
# Option A: Google App Password (RECOMMENDED - quickest setup)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=al@thefungroupmiami.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Option B: Full OAuth (advanced)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# ── GoHighLevel Configuration ──
# Each sub-account has its own API key
# Found at: Settings → Business Profile → API Key
GHL_API_KEY_WERENTFUN=eyJh...paste_full_key_here
GHL_API_KEY_JUSTBOUNCE=eyJh...paste_full_key_here
GHL_API_KEY_LASERTAG=

# Location IDs (from the URL: /location/XXXXX/dashboard)
GHL_LOCATION_WERENTFUN=PTyW19tTYDGTqHpgoxsy
GHL_LOCATION_JUSTBOUNCE=
GHL_LOCATION_LASERTAG=

# ── RingCentral Configuration (Phase 2 — optional for now) ──
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_JWT_TOKEN=
RC_SERVER_URL=https://platform.ringcentral.com

# ── Application ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
